# OpenRouter API Configuration for Backend Proxy
# This file shows the required environment variables
# NEVER commit actual API keys - this file is for reference only

# Get your API key from https://openrouter.ai
# Backend server uses this to call OpenRouter securely
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Backend server port (optional, defaults to 3001)
PORT=3001

